{
  "name": "@webapp/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "npm run test:unit && npm run test:api",
    "test:unit": "vitest run test/unit",
    "test:api": "vitest run test/api",
    "test:integration": "vitest run test/db --passWithNoTests"
  },
  "dependencies": {
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
